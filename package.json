{
    "name": "node-red-contrib-pap-ui",
    "version": "0.1.0",
    "description": "Standalone home automation dashboard for Node-RED — no Dashboard 2.0 required",
    "keywords": [
        "node-red",
        "node-red-dashboard",
        "smarthome",
        "dashboard",
        "home-automation",
        "iot",
        "ui"
    ],
    "license": "Apache-2.0",
    "author": "Davide Travaglini",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/davide-travaglini/node-red-contrib-pap-ui.git"
    },
    "bugs": {
        "url": "https://github.com/davide-travaglini/node-red-contrib-pap-ui/issues"
    },
    "homepage": "https://github.com/davide-travaglini/node-red-contrib-pap-ui#readme",
    "files": [
        "nodes/**",
        "resources/dist/**"
    ],
    "scripts": {
        "build": "vite build",
        "build:dev": "NODE_ENV=development vite build",
        "dev": "NODE_ENV=development vite build --watch",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "express": "^4.18.0",
        "socket.io": "^4.7.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "pinia": "^2.1.0",
        "socket.io-client": "^4.7.0",
        "vite": "^5.0.13",
        "vue": "^3.4.0",
        "vue-router": "^4.3.0"
    },
    "engines": {
        "node": ">=18"
    },
    "node-red": {
        "version": ">=3.1.0",
        "nodes": {
            "ui-pap-server": "nodes/ui-pap-server/ui-pap-server.js",
            "ui-pap-area": "nodes/ui-pap-area/ui-pap-area.js",
            "ui-pap-page": "nodes/ui-pap-page/ui-pap-page.js",
            "ui-pap-group": "nodes/ui-pap-group/ui-pap-group.js",
            "ui-pap-subgroup": "nodes/ui-pap-subgroup/ui-pap-subgroup.js",
            "ui-pap-switch": "nodes/widgets/ui-pap-switch/ui-pap-switch.js",
            "ui-pap-sensor": "nodes/widgets/ui-pap-sensor/ui-pap-sensor.js",
            "ui-pap-gauge": "nodes/widgets/ui-pap-gauge/ui-pap-gauge.js"
        }
    }
}
